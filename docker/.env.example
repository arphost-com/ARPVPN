# Copy this file to ".env" in the same folder and adjust values as needed.

# Registry image/tag to run.
# v1 line (`main`):         10.10.10.96:5050/arphost/arpvpn:stable
# v2 line (`multitenant`):  10.10.10.96:5050/arphost/arpvpn:v2-latest
ARPVPN_IMAGE=10.10.10.96:5050/arphost/arpvpn:v2-latest

# Runtime user inside the container.
# Leave as "arpvpn" unless you build an image with a custom user/sudo policy.
ARPVPN_RUNTIME_USER=arpvpn

# Container name.
# Set a unique value per stack when running multiple ARPVPN containers on one host.
ARPVPN_CONTAINER_NAME=arpvpn

# Optional explicit suffix used to derive cookie names.
# Useful when multiple stacks share one hostname and you want stable cookie namespaces.
# ARPVPN_COOKIE_SUFFIX=arpvpn_v2

# Optional explicit cookie names (useful when multiple stacks share one hostname).
# If unset, names are auto-derived from ARPVPN_CONTAINER_NAME.
# ARPVPN_SESSION_COOKIE_NAME=arpvpn_session
# ARPVPN_REMEMBER_COOKIE_NAME=arpvpn_session_remember

# 0 for mixed HTTP+HTTPS deployments, 1 for strict HTTPS-only cookies.
ARPVPN_SECURE_COOKIES=0

# HTTP bind port. In host network mode this is the host port too.
ARPVPN_HTTP_PORT=8085

# HTTPS bind port. In host network mode this is the host port too.
ARPVPN_HTTPS_PORT=8086

# Host folder mounted to /data inside container.
# Compose will create this path automatically on first startup.
DATA_FOLDER=./data
# For parallel installs, keep dedicated state paths per release line:
# v1 example: /srv/arpvpn-v1/data
# v2 example: /srv/arpvpn-v2/data

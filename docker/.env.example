# Copy this file to ".env" in the same folder and adjust values as needed.

# Registry image/tag to run.
ARPVPN_IMAGE=10.10.10.96:5050/arphost/arpvpn:stable

# Runtime UID:GID for the container process.
# Match these to ownership of DATA_FOLDER on the host.
ARPVPN_UID=1000
ARPVPN_GID=1000

# 0 for HTTP deployments, 1 when served behind HTTPS.
ARPVPN_SECURE_COOKIES=0

# Host folder mounted to /data inside container.
DATA_FOLDER=/srv/arpvpn/data

# Copy this file to ".env" in the same folder and adjust values as needed.

# Image/tag to run.
# Default is a local image built from this bundle.
ARPVPN_IMAGE=arpvpn:local

# Runtime user inside the container.
# Leave as "arpvpn" unless you build an image with a custom user/sudo policy.
ARPVPN_RUNTIME_USER=arpvpn

# UID/GID used when building the image's "arpvpn" runtime user.
# Set these to match the host owner of DATA_FOLDER when the default 1000:1000
# does not fit your server.
ARPVPN_UID=1000
ARPVPN_GID=1000

# Container name.
# Set a unique value per stack when running multiple ARPVPN containers on one host.
ARPVPN_CONTAINER_NAME=arpvpn

# Optional explicit suffix used to derive cookie names.
# Useful when multiple stacks share one hostname and you want stable cookie namespaces.
# ARPVPN_COOKIE_SUFFIX=arpvpn_v2

# Optional explicit cookie names (useful when multiple stacks share one hostname).
# If unset, names are auto-derived from ARPVPN_CONTAINER_NAME.
# ARPVPN_SESSION_COOKIE_NAME=arpvpn_session
# ARPVPN_REMEMBER_COOKIE_NAME=arpvpn_session_remember

# 0 for mixed HTTP+HTTPS deployments, 1 for strict HTTPS-only cookies.
ARPVPN_SECURE_COOKIES=0

# HTTP bind port. In host network mode this is the host port too.
ARPVPN_HTTP_PORT=8085

# HTTPS bind port. In host network mode this is the host port too.
ARPVPN_HTTPS_PORT=8086

# Host folder mounted to /data inside container.
# Compose will create this path automatically on first startup.
DATA_FOLDER=./data
# For parallel installs, keep dedicated state paths per stack:
# example A: /srv/arpvpn-a/data
# example B: /srv/arpvpn-b/data

# Optional runtime tuning. Uncomment only when you need to override defaults.
# ARPVPN_HIGH_TRAFFIC_THRESHOLD_MB=1024
# ARPVPN_RRD_GRAPH_CACHE_TTL_SECONDS=10800
# ARPVPN_LOG_DIAGNOSTICS_CACHE_TTL_SECONDS=5
# ARPVPN_LOG_DIAGNOSTICS_READ_BLOCK_BYTES=65536
# ARPVPN_API_ACCESS_TTL_SECONDS=900
# ARPVPN_API_REFRESH_TTL_SECONDS=86400
# ARPVPN_API_AUTH_WINDOW_SECONDS=60
# ARPVPN_API_AUTH_MAX_ATTEMPTS=8
# ARPVPN_API_AUTH_LOCKOUT_SECONDS=300
# ARPVPN_API_RATE_LIMIT_WINDOW_SECONDS=60
# ARPVPN_API_RATE_LIMIT_MAX_REQUESTS=120

# Optional API group feature flags. Set a value to 0/false/no/off to disable.
# ARPVPN_FEATURE_API_AUTH=1
# ARPVPN_FEATURE_API_STATS=1
# ARPVPN_FEATURE_API_SYSTEM=1
# ARPVPN_FEATURE_API_TLS=1
# ARPVPN_FEATURE_API_CONFIG=1
# ARPVPN_FEATURE_API_TENANTS=1
# ARPVPN_FEATURE_API_WIREGUARD=1

# Optional audit/signing, tenant runtime, and metadata overrides.
# ARPVPN_AUDIT_SIGNING_KEY=
# ARPVPN_TENANT_RUNTIME_PORT_STRIDE=10
# ARPVPN_TENANT_RUNTIME_HTTP_BASE=18085
# ARPVPN_TENANT_RUNTIME_HTTPS_BASE=18086
# ARPVPN_TENANT_RUNTIME_VPN_BASE=51820
# ARPVPN_REPOSITORY_URL=
# ARPVPN_LICENSE_URL=
